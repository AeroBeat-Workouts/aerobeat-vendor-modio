# Godot 4+ specific ignores
.godot/
.import/
export_presets.cfg

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# System specific
.DS_Store
Thumbs.db
.nomedia

# GodotEnv package workbench
.testbed/addons/*
!.testbed/addons/.editorconfig
.testbed/.addons/

# mod.io local config (testbed only)
.testbed/*.local.cfg

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Godot UID sidecars
*.uid
